```python
def debug_log(node: str, step: str, message: str) -> None:
    """输出调试日志"""
    print(f"[DEBUG {node}/{step}] {message}")
    if DEBUG_MODE:
        logging.warning(f"[DEBUG {node}/{step}] {message}")
        # 写入文件
```

